# === MySQL ===
MYSQL_DATABASE=datadinosaur
MYSQL_USER=dduser
MYSQL_PASSWORD=changeme_strong_password
MYSQL_ROOT_PASSWORD=changeme_root_password

# === Admin login ===
# Generate hash: php scripts/hash-password.php yourpassword
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=$2y$12$replace_this_with_bcrypt_hash

# === Publish API (used by Claude skill to post directly) ===
# Generate with: openssl rand -hex 32
APP_SECRET=changeme_random_secret

# === Domain ===
DOMAIN=my.datadinosaur.com
CERTBOT_EMAIL=jeremy@datadinosaur.com

# === RAG service ===
# Gemini API key from aistudio.google.com (free)
GEMINI_API_KEY=your-gemini-api-key
# Shared secret between PHP and Python RAG service — generate: openssl rand -hex 32
RAG_SECRET=changeme_rag_secret
# Internal URL of the RAG container (default works with docker-compose)
RAG_URL=http://rag:8000
# pgvector DB credentials
PG_DB=rag
PG_USER=rag
PG_PASSWORD=changeme_pg_password

# === Contact email (PHPMailer) ===
CONTACT_TO_EMAIL=jeremy@datadinosaur.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-smtp-user@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM_EMAIL=noreply@datadinosaur.com
SMTP_FROM_NAME=DataDinosaur
